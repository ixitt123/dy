[
  {
    "segment_id": "seg-001",
    "scene_index": 1,
    "text": "暑假补课最怕的，不是孩子暂时没听懂。",
    "start_time": 0,
    "end_time": 3.35,
    "image_asset_id": "0015dfc6-2a8a-4483-9c81-b2c4e00cb854",
