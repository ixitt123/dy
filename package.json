{
  "name": "douyin-mcp-local-runner",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node ui-server.mjs",
    "start:hidden": "wscript.exe start-ui-hidden.vbs",
    "start:mcp": "node node_modules/@yc-w-cn/douyin-mcp-server/dist/index.js",
    "dev": "node ui-server.mjs --open",
    "check": "node check-install.mjs",
    "test:e2e": "node test-e2e.mjs",
    "test:pipeline": "node test-pipeline.mjs",
    "test:pipeline:fail-policy": "node test-pipeline-runner-fail-policy.mjs",
    "test:task-duration": "node test-task-center-duration.mjs",
    "test:provider-registry": "node test-provider-registry.mjs",
    "test:http-body": "node test-read-json-body.mjs",
    "test:config": "node test-config-extraction.mjs",
    "test:record-cleanup": "node test-record-cleanup.mjs",
    "test:image-normalize": "node test-image-normalize-filter.mjs",
    "patch-output": "node patch-mcp-output.mjs",
    "postinstall": "node patch-mcp-output.mjs"
  },
  "dependencies": {
    "@yc-w-cn/douyin-mcp-server": "1.0.4",
    "capcut-cli": "0.11.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "gsap": "3.14.2",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ffmpeg-static"
    ]
  }
}
