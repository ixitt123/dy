{
  "name": "douyin-mcp-local-runner",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node ui-server.mjs",
    "start:hidden": "wscript.exe start-ui-hidden.vbs",
    "start:mcp": "node node_modules/@yc-w-cn/douyin-mcp-server/dist/index.js",
    "dev": "node ui-server.mjs --open",
    "check": "node check-install.mjs && node test-download-safety.mjs && node test-xiaohei-prompt-copy.mjs && node test-moments-original-mode.mjs && node test-rewrite-completeness.mjs && node test-tts-handoff-subtitle-correction.mjs && node test-page-lifecycle.mjs",
    "test:e2e": "node test-e2e.mjs",
    "test:pipeline": "node test-pipeline.mjs",
    "test:pipeline:fail-policy": "node test-pipeline-runner-fail-policy.mjs",
    "test:task-duration": "node test-task-center-duration.mjs",
    "test:yt-dlp": "node test-yt-dlp-service.mjs",
    "test:provider-registry": "node test-provider-registry.mjs",
    "test:http-body": "node test-read-json-body.mjs",
    "test:config": "node test-config-extraction.mjs",
    "test:record-cleanup": "node test-record-cleanup.mjs",
    "test:image-normalize": "node test-image-normalize-filter.mjs",
    "test:kinetic-preview-seek": "node test-kinetic-preview-seek.mjs",
    "test:kinetic-overlay-position": "node test-kinetic-overlay-position.mjs",
    "test:kinetic-illustration-toggle": "node test-kinetic-illustration-toggle.mjs",
    "test:minimax-tts": "node test-minimax-tts.mjs",
    "test:tts-alignment": "node test-tts-alignment.mjs",
    "test:tts-alignment-service": "node test-tts-alignment-service.mjs",
    "test:tts-handoff-subtitle-correction": "node test-tts-handoff-subtitle-correction.mjs",
    "test:subtitle-templates": "node test-subtitle-templates.mjs",
    "test:subtitle-render": "node test-subtitle-render.mjs",
    "test:xiaohei-skill-routing": "node test-xiaohei-skill-routing.mjs",
    "test:xiaohei-video-render": "node test-xiaohei-video-render.mjs",
    "test:moments-original": "node test-moments-original-mode.mjs",
    "test:rewrite-completeness": "node test-rewrite-completeness.mjs",
    "test:page-lifecycle": "node test-page-lifecycle.mjs",
    "test:download-safety": "node test-download-safety.mjs",
    "patch-output": "node patch-mcp-output.mjs",
    "postinstall": "node patch-mcp-output.mjs"
  },
  "dependencies": {
    "@yc-w-cn/douyin-mcp-server": "1.0.4",
    "archiver": "7.0.1",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "gsap": "3.14.2",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ffmpeg-static"
    ]
  }
}
